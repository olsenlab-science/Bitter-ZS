Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"tMOT", " ", "=", "8"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Thickness", " ", "of", " ", "the", " ", "wire"}], "+", 
     "coatings"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rintubeMOT", "=", "2.413"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Inner", " ", "radius", " ", "of", " ", "tubing"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"routtubeMOT", "=", "3.175"}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Outer", " ", "radius", " ", "of", " ", "tubing"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"turnMOT", " ", "=", " ", "4"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "Number", " ", "of", " ", "turns", " ", "of", " ", "wire", " ", "on", " ",
      "coil"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"layerMOT", " ", "=", " ", "4"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{
    "Number", " ", "of", " ", "layers", " ", "of", " ", "wire", " ", "on", 
     " ", "coil"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rinMOT", " ", "=", "80"}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Inner", " ", "radius", " ", "of", " ", "coil"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"routMOT", " ", "=", 
     RowBox[{"rinMOT", " ", "+", " ", 
      RowBox[{"turnMOT", "*", "tMOT"}]}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Outer", " ", "radius", " ", "of", " ", "coil"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"IMOT", " ", "=", " ", 
     RowBox[{
     "currents", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
    ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Current", " ", "flowing", " ", "through", " ", "coil"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"IMOTH", " ", "=", " ", 
     RowBox[{
     "currents", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
    ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"Current", " ", "flowing", " ", "through", " ", "coil"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"sepMOT", " ", "=", "67"}], " ", 
   RowBox[{"(*", 
    RowBox[{"77", ";"}], " ", 
    RowBox[{"(*", 
     RowBox[{
     "Separation", " ", "between", " ", "inner", " ", "surfaces", " ", "of", 
      " ", "coils"}], "*)"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"AMOT", "=", 
     RowBox[{"\[Pi]", "*", 
      SuperscriptBox["10", 
       RowBox[{"-", "6"}]], 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["routtubeMOT", "2"], "-", 
        SuperscriptBox["rintubeMOT", "2"]}], ")"}]}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"cross", "-", 
     RowBox[{"section", " ", "area", " ", "of", " ", "copper", " ", "in", " ", 
      SuperscriptBox["m", "2"]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lenMOT", " ", "=", " ", 
     RowBox[{"2", "\[Pi]", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"rinMOT", "*", "turnMOT"}], "+", 
        RowBox[{
         RowBox[{"Sum", "[", 
          RowBox[{"n", ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "1", ",", 
             RowBox[{"turnMOT", "-", "1"}]}], "}"}]}], "]"}], "*", "tMOT"}]}],
        ")"}], "*", "layerMOT", "*", ".001"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
    "length", " ", "of", " ", "MOT", " ", "copper", " ", "in", " ", "m"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"RMOT", "=", 
     RowBox[{"\[Rho]Cu", "*", 
      FractionBox["lenMOT", "AMOT"]}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"resistance", " ", "of", " ", "one", " ", "MOT", " ", "coil"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"VMOT", "=", 
     RowBox[{"IMOT", "*", "2", "*", "RMOT"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
    "voltage", " ", "drop", " ", "for", " ", "both", " ", "MOT", " ", 
     "coils"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PMOT", "=", 
     RowBox[{
      SuperscriptBox["IMOT", "2"], "*", "2", "*", "RMOT"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{
    "power", " ", "dissipated", " ", "in", " ", "both", " ", "MOT", " ", 
     "coils"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"LMOT", "=", 
     RowBox[{"\[Mu]0", " ", 
